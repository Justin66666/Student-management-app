<div class="bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="sm:flex sm:items-center">
      <div class="sm:flex-auto">
        <h1 class="text-3xl font-semibold leading-6 text-gray-900">CSE <%= @course.course_number %></h1>
        <h2 class="mt-2 text-xl text-gray-700"><%= @course.title %></h2>
      </div>
      <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
        <% if current_user.admin? %>
          <%= link_to "Edit Course", edit_admin_course_path(@course), class: "rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600" %>
        <% end %>
      </div>
    </div>

    <div class="mt-8 bg-white p-6 rounded-lg shadow">
      <dl class="divide-y divide-gray-100">
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-0">
          <dt class="text-sm font-medium leading-6 text-gray-900">Course Number</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">CSE <%= @course.course_number %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-0">
          <dt class="text-sm font-medium leading-6 text-gray-900">Title</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @course.title %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-0">
          <dt class="text-sm font-medium leading-6 text-gray-900">Description</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @course.description %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-0">
          <dt class="text-sm font-medium leading-6 text-gray-900">Term</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @course.formatted_term %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-0">
          <dt class="text-sm font-medium leading-6 text-gray-900">Campus</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @course.formatted_campus %></dd>
        </div>
      </dl>
    </div>

    <div class="mt-6 flex items-center justify-end gap-x-6">
      <%= link_to "Back to Courses", courses_path, class: "text-sm font-semibold leading-6 text-gray-900" %>
      <% if current_user.admin? %>
        <%= button_to "Delete Course", admin_course_path(@course), method: :delete, class: "rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600", data: { confirm: "Are you sure you want to delete this course?" } %>
      <% end %>
    </div>

    <!-- Course Sections -->
    <div class="mt-8">
      <h3 class="text-xl font-semibold text-gray-900 mb-6">Available Sections</h3>
      
      <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-300">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Section</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Instructor</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Schedule</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Location</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Enrollment</th>
              <% if current_user.student? %>
                <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                  <span class="sr-only">Apply</span>
                </th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% @sections.each do |section| %>
              <tr>
                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6"><%= section.number %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= section.instructor_name %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= section.schedule %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= section.location %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                  <%= section.current_enrollment %> / <%= section.max_enrollment %>
                </td>
                <% if current_user.student? %>
                  <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                    <%= button_to "Apply as Grader", 
                        new_student_application_path(section_id: section.id),
                        method: :get,
                        class: "text-blue-600 hover:text-blue-900",
                        data: { turbo_frame: "_top" } %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Additional Course Information -->
    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
      <div class="bg-gray-50 px-4 py-5 shadow sm:rounded-lg sm:p-6">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Prerequisites</h3>
        <div class="mt-2 text-sm text-gray-500">
          <p><%= @course.prerequisites || "None" %></p>
        </div>
      </div>

      <div class="bg-gray-50 px-4 py-5 shadow sm:rounded-lg sm:p-6">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Grader Requirements</h3>
        <div class="mt-2 text-sm text-gray-500">
          <ul class="list-disc pl-5 space-y-1">
            <li>Must have completed the course with a grade of B or better</li>
            <li>Must be available during scheduled lab times</li>
            <li>Strong understanding of course material required</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div> 