<div class="bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="sm:flex sm:items-center">
      <div class="sm:flex-auto">
        <h1 class="text-3xl font-semibold leading-6 text-gray-900">Edit Course</h1>
        <p class="mt-2 text-sm text-gray-700">Edit course information below.</p>
      </div>
    </div>

    <div class="mt-8 bg-white p-6 rounded-lg shadow">
      <%= form_with(model: @course, local: true, class: "space-y-6") do |f| %>
        <% if @course.errors.any? %>
          <div class="bg-red-50 p-4 rounded-md">
            <h2 class="text-sm font-medium text-red-800">
              <%= pluralize(@course.errors.count, "error") %> prohibited this course from being saved:
            </h2>
            <ul class="mt-3 list-disc list-inside text-sm text-red-800">
              <% @course.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-2">
          <div>
            <%= f.label :title, class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
              <%= f.text_field :title, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" %>
            </div>
          </div>

          <div>
            <%= f.label :course_number, class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
              <%= f.number_field :course_number, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" %>
            </div>
          </div>

          <div class="sm:col-span-2">
            <%= f.label :description, class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
              <%= f.text_area :description, rows: 4, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" %>
            </div>
          </div>

          <div>
            <%= f.label :term, class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
              <%= f.select :term,
                  options_for_select([
                    ["Spring 2024", "1242"],
                    ["Summer 2024", "1244"],
                    ["Autumn 2024", "1248"],
                    ["Spring 2025", "1252"]
                  ], @course.term),
                  {},
                  class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" %>
            </div>
          </div>

          <div>
            <%= f.label :campus, class: "block text-sm font-medium leading-6 text-gray-900" %>
            <div class="mt-2">
              <%= f.select :campus,
                  options_for_select([
                    ["Columbus", "col"],
                    ["Lima", "lma"],
                    ["Mansfield", "mns"],
                    ["Marion", "mrn"],
                    ["Newark", "nwk"]
                  ], @course.campus),
                  {},
                  class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" %>
            </div>
          </div>
        </div>

        <div class="mt-6 flex items-center justify-end gap-x-6">
          <%= link_to "Cancel", course_path(@course), class: "text-sm font-semibold leading-6 text-gray-900" %>
          <%= f.submit "Update Course", class: "rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600" %>
        </div>
      <% end %>
    </div>
  </div>
</div> 