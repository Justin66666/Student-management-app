<div class="container">
  <div class="row mb-4">
    <div class="col">
      <h1>Course Catalog</h1>
      <p class="text-muted">Browse available CSE courses and their sections.</p>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-md-6">
      <%= form_tag courses_path, method: :get, class: 'form-inline' do %>
        <div class="input-group">
          <%= text_field_tag :search, params[:search], class: 'form-control', placeholder: 'Search by course number or title' %>
          <div class="input-group-append">
            <%= submit_tag 'Search', class: 'btn btn-primary' %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="col-md-3">
      <%= select_tag :level,
          options_for_select([
            ['All Levels', 'all'],
            ['1000 Level', '1'],
            ['2000 Level', '2'],
            ['3000 Level', '3'],
            ['4000 Level', '4'],
            ['5000 Level', '5']
          ], params[:level]),
          class: 'form-select',
          onchange: 'this.form.submit()' %>
    </div>
    <div class="col-md-3">
      <div class="dropdown">
        <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
          Sort by: <%= params[:sort]&.titleize || 'Course Number (Asc)' %>
        </button>
        <ul class="dropdown-menu">
          <li>
            <%= link_to 'Course Number (Asc)', courses_path(sort: 'number_asc', search: params[:search], level: params[:level]), 
                class: "dropdown-item #{params[:sort] == 'number_asc' ? 'active' : ''}" %>
          </li>
          <li>
            <%= link_to 'Course Number (Desc)', courses_path(sort: 'number_desc', search: params[:search], level: params[:level]), 
                class: "dropdown-item #{params[:sort] == 'number_desc' ? 'active' : ''}" %>
          </li>
          <li>
            <%= link_to 'Title (A-Z)', courses_path(sort: 'title_asc', search: params[:search], level: params[:level]), 
                class: "dropdown-item #{params[:sort] == 'title_asc' ? 'active' : ''}" %>
          </li>
          <li>
            <%= link_to 'Title (Z-A)', courses_path(sort: 'title_desc', search: params[:search], level: params[:level]), 
                class: "dropdown-item #{params[:sort] == 'title_desc' ? 'active' : ''}" %>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col">
      <% if @courses.any? %>
        <div class="table-responsive">
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Course Number</th>
                <th>Title</th>
                <th>Term</th>
                <th>Campus</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @courses.each do |course| %>
                <tr>
                  <td><%= course.subject %> <%= course.course_number %></td>
                  <td><%= course.title %></td>
                  <td><%= course.formatted_term %></td>
                  <td><%= course.formatted_campus %></td>
                  <td>
                    <%= link_to 'View', course_path(course), class: 'btn btn-sm btn-info' %>
                    <% if current_user.student? %>
                      <%= link_to 'Apply', new_student_application_path(course_id: course.id), class: 'btn btn-sm btn-primary' %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        
        <div class="d-flex justify-content-center">
          <%= paginate @courses %>
        </div>
      <% else %>
        <div class="alert alert-info">
          No courses found matching your criteria.
        </div>
      <% end %>
    </div>
  </div>
</div>
