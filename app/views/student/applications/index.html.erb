<div class="container">
  <div class="row mb-4">
    <div class="col">
      <h1>My Applications</h1>
      <%= link_to 'New Application', new_student_application_path, class: 'btn btn-primary float-end' %>
    </div>
  </div>

  <% if @applications.any? %>
    <div class="table-responsive">
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Course</th>
            <th>Position</th>
            <th>Status</th>
            <th>Submitted</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @applications.each do |application| %>
            <tr>
              <td>
                <%= "#{application.course.subject} #{application.course.course_number}" %>
                <br>
                <small class="text-muted"><%= application.course.title %></small>
              </td>
              <td><%= application.position_type.titleize %></td>
              <td>
                <span class="badge <%= application.status == 'pending' ? 'bg-warning' : (application.status == 'approved' ? 'bg-success' : 'bg-danger') %>">
                  <%= application.status.titleize %>
                </span>
              </td>
              <td><%= application.created_at.strftime("%B %d, %Y") %></td>
              <td>
                <%= link_to 'View', student_application_path(application), class: 'btn btn-sm btn-info' %>
                <%= link_to 'Edit', [:edit, :student, application], class: 'btn btn-sm btn-primary' %>
                <%= button_to 'Withdraw', student_application_path(application), 
                    method: :delete, 
                    class: 'btn btn-sm btn-danger',
                    data: { confirm: 'Are you sure you want to withdraw this application?' } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-info">
      <p class="mb-0">You haven't submitted any applications yet.</p>
    </div>
  <% end %>
</div> 