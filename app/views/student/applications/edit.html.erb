<div class="container">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <h1>Edit Application</h1>
      
      <% if @application.status != 'pending' %>
        <div class="alert alert-info">
          <p>Note: Your application is currently <strong><%= @application.status.titleize %></strong>. 
          Editing this application will not change its status, but the updated information will be visible to admins.</p>
        </div>
      <% end %>

      <%= form_with(model: [:student, @application], local: true, class: 'mt-4') do |f| %>
        <% if @application.errors.any? %>
          <div class="alert alert-danger">
            <h2><%= pluralize(@application.errors.count, "error") %> prohibited this application from being saved:</h2>
            <ul>
              <% @application.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :course_id, 'Course', class: 'form-label' %>
          <%= f.collection_select :course_id, Course.all.order(:subject, :course_number), :id, 
              ->(course) { "#{course.subject} #{course.course_number} - #{course.title}" },
              { disabled: true }, 
              { class: 'form-select', disabled: true } %>
          <%= f.hidden_field :course_id %>
        </div>

        <div class="mb-3">
          <%= f.label :position_type, 'Position Type', class: 'form-label' %>
          <%= f.select :position_type, 
              Application.position_types.keys.map { |type| [type.titleize, type] },
              { prompt: 'Select position type' },
              { class: 'form-select' } %>
        </div>

        <div class="mb-3">
          <%= f.label :experience, 'Related Experience', class: 'form-label' %>
          <%= f.text_area :experience, class: 'form-control', rows: 5,
              placeholder: 'Describe your relevant experience, including courses taken, projects completed, and any teaching or tutoring experience.' %>
        </div>

        <div class="mb-3">
          <%= f.label :programming_languages, 'Programming Languages', class: 'form-label' %>
          <%= f.text_field :programming_languages, class: 'form-control',
              placeholder: 'List programming languages you are proficient in (e.g., Java, Python, C++)' %>
        </div>

        <div class="mb-3">
          <%= f.label :available_hours, 'Available Hours per Week', class: 'form-label' %>
          <%= f.number_field :available_hours, class: 'form-control', min: 1, max: 20 %>
        </div>

        <div class="d-flex justify-content-between mt-4">
          <%= link_to 'Back', student_applications_path, class: 'btn btn-secondary' %>
          <%= f.submit 'Update Application', class: 'btn btn-primary' %>
        </div>
      <% end %>
    </div>
  </div>
</div> 