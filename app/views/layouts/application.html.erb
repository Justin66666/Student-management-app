<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "CSE Grader Management" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <%= link_to "CSE Grader", root_path, class: "text-xl font-bold text-gray-800" %>
            </div>
            <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
              <%= link_to "Home", root_path, class: "inline-flex items-center px-1 pt-1 text-gray-500 hover:text-gray-700" %>
              <%= link_to "Course Catalog", courses_path, class: "inline-flex items-center px-1 pt-1 text-gray-500 hover:text-gray-700" %>
              
              <% if user_signed_in? %>
                <% if current_user.student? %>
                  <%= link_to "My Applications", student_applications_path, class: "inline-flex items-center px-1 pt-1 text-gray-500 hover:text-gray-700" %>
                <% end %>
                
                <% if current_user.instructor? %>
                  <%= link_to "My Courses", instructor_courses_path, class: "inline-flex items-center px-1 pt-1 text-gray-500 hover:text-gray-700" %>
                  <%= link_to "Submit Recommendation", new_recommendation_letter_path, class: "inline-flex items-center px-1 pt-1 text-gray-500 hover:text-gray-700" %>
                <% end %>
                
                <% if current_user.admin? %>
                  <%= link_to "Users", admin_users_path, class: "inline-flex items-center px-1 pt-1 text-gray-500 hover:text-gray-700" %>
                  <%= link_to "Applications", admin_applications_path, class: "inline-flex items-center px-1 pt-1 text-gray-500 hover:text-gray-700" %>
                  <%= link_to "Grader Assignments", admin_grader_assignments_path, class: "inline-flex items-center px-1 pt-1 text-gray-500 hover:text-gray-700" %>
                  <%= link_to "Reload Courses", admin_courses_reload_path, class: "inline-flex items-center px-1 pt-1 text-gray-500 hover:text-gray-700" %>
                <% end %>
              <% end %>
            </div>
          </div>
          <div class="flex items-center">
            <% if user_signed_in? %>
              <div class="ml-3 relative">
                <div class="flex items-center space-x-4">
                  <span class="text-gray-700"><%= current_user.email %></span>
                  <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "text-gray-500 hover:text-gray-700" %>
                </div>
              </div>
            <% else %>
              <div class="space-x-4">
                <%= link_to "Login", new_user_session_path, class: "text-gray-500 hover:text-gray-700" %>
                <%= link_to "Sign Up", new_user_registration_path, class: "bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-600" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative" role="alert">
          <span class="block sm:inline"><%= notice %></span>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
          <span class="block sm:inline"><%= alert %></span>
        </div>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>
  </body>
</html>
