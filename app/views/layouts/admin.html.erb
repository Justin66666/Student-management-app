<!DOCTYPE html>
<html>
  <head>
    <title>Course Catalog Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%= link_to 'Course Catalog Admin', admin_users_path, class: 'navbar-brand' %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav">
            <li class="nav-item">
              <%= link_to 'Home', root_path, class: 'nav-link btn btn-primary text-white me-2' %>
            </li>
            <li class="nav-item">
              <%= link_to 'Users', admin_users_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to 'Courses', admin_courses_reload_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to 'Applications', admin_applications_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to 'Grader Assignments', admin_grader_assignments_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to admin_recommendation_letters_path, class: "nav-link #{'active fw-bold' if controller_name == 'recommendation_letters'}" do %>
                <% pending_recommendations = RecommendationLetter.where(status: 'pending').count %>
                <% if pending_recommendations > 0 %>
                  <span class="badge bg-warning text-dark rounded-pill me-1"><%= pending_recommendations %></span>
                <% end %>
                Teacher Recommendations
              <% end %>
            </li>
          </ul>
          <ul class="navbar-nav ms-auto">
            <% if user_signed_in? %>
              <li class="nav-item">
                <span class="nav-link">Welcome, <%= current_user.email %></span>
              </li>
              <li class="nav-item">
                <%= button_to 'Sign Out', destroy_user_session_path, method: :delete, class: 'btn btn-link nav-link' %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container mt-4">
      <% if notice %>
        <div class="alert alert-success" role="alert">
          <%= notice %>
        </div>
      <% end %>
      
      <% if alert %>
        <div class="alert alert-danger" role="alert">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html> 