<div class="container mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-6">Edit Course</h1>

  <%= form_with(model: [:admin, @course], class: "max-w-lg") do |form| %>
    <% if @course.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <h2 class="font-bold"><%= pluralize(@course.errors.count, "error") %> prohibited this course from being saved:</h2>
        <ul class="list-disc list-inside">
          <% @course.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= form.label :subject, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= form.text_field :subject, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-4">
      <%= form.label :course_number, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= form.number_field :course_number, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-4">
      <%= form.label :title, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= form.text_field :title, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-4">
      <%= form.label :description, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= form.text_area :description, rows: 4, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-4">
      <%= form.label :term, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= form.text_field :term, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-4">
      <%= form.label :campus, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= form.text_field :campus, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-4">
      <%= form.label :prerequisites, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= form.text_area :prerequisites, rows: 3, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="flex items-center justify-between">
      <%= form.submit "Update Course", class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline" %>
      <%= link_to "Cancel", admin_courses_path, class: "text-blue-500 hover:text-blue-800" %>
    </div>
  <% end %>
</div> 