<div class="container mt-4">
  <h1>Grader Assignments</h1>
  
  <div class="row mb-4">
    <div class="col">
      <div class="card">
        <div class="card-header bg-primary text-white">
          <div class="d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Course Sections and Assigned Graders</h2>
            <div class="d-flex">
              <input type="text" id="course-search" class="form-control form-control-sm me-2" placeholder="Filter by course...">
              <select id="status-filter" class="form-select form-select-sm" style="width: 150px;">
                <option value="all">All Sections</option>
                <option value="needs">Needs Graders</option>
                <option value="staffed">Fully Staffed</option>
              </select>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table id="sections-table" class="table table-striped table-hover">
              <thead>
                <tr>
                  <th>Course</th>
                  <th>Section</th>
                  <th>Instructor</th>
                  <th>Graders Required</th>
                  <th>Graders Assigned</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @sections.each do |section| %>
                  <tr class="section-row <%= section.graders.count < section.graders_required ? 'table-warning needs-graders' : 'table-success fully-staffed' %>" 
                      data-course="<%= section.course.subject %> <%= section.course.course_number %> - <%= section.course.title %>">
                    <td><%= section.course.subject %> <%= section.course.course_number %></td>
                    <td><%= section.number %></td>
                    <td><%= section.instructor_name %></td>
                    <td>
                      <%= form_with url: update_graders_required_admin_grader_assignments_path, method: :patch, class: 'd-flex' do |f| %>
                        <%= f.hidden_field :section_id, value: section.id %>
                        <%= f.number_field :graders_required, value: section.graders_required, min: 0, class: 'form-control form-control-sm me-2', style: 'width: 70px;' %>
                        <%= f.submit 'Update', class: 'btn btn-sm btn-outline-primary' %>
                      <% end %>
                    </td>
                    <td><%= section.graders.count %> / <%= section.graders_required %></td>
                    <td>
                      <% if section.graders.count < section.graders_required %>
                        <span class="badge bg-warning">Needs Graders</span>
                      <% else %>
                        <span class="badge bg-success">Fully Staffed</span>
                      <% end %>
                    </td>
                    <td>
                      <button class="btn btn-sm btn-info" type="button" data-bs-toggle="collapse" data-bs-target="#section<%= section.id %>Details">
                        Show Assigned Graders
                      </button>
                    </td>
                  </tr>
                  <tr class="collapse" id="section<%= section.id %>Details">
                    <td colspan="7">
                      <div class="p-3 bg-light rounded">
                        <h6>Assigned Graders</h6>
                        <% if section.graders.any? %>
                          <table class="table table-sm">
                            <thead>
                              <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Position</th>
                                <th>Hours</th>
                                <th>Action</th>
                              </tr>
                            </thead>
                            <tbody>
                              <% section.graders.each do |grader| %>
                                <tr>
                                  <td><%= grader.user.name rescue 'N/A' %></td>
                                  <td><%= grader.user.email %></td>
                                  <td><%= grader.position_type.titleize %></td>
                                  <td><%= grader.hours_per_week %> hrs/week</td>
                                  <td>
                                    <%= form_with url: unassign_grader_admin_grader_assignments_path, method: :patch do |f| %>
                                      <%= f.hidden_field :application_id, value: grader.id %>
                                      <%= f.submit 'Unassign', class: 'btn btn-sm btn-danger', data: { confirm: 'Are you sure you want to unassign this grader?' } %>
                                    <% end %>
                                  </td>
                                </tr>
                              <% end %>
                            </tbody>
                          </table>
                        <% else %>
                          <p class="text-muted">No graders assigned yet.</p>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col">
      <div class="card">
        <div class="card-header bg-success text-white">
          <h2 class="h5 mb-0">Approved Graders (Unassigned)</h2>
        </div>
        <div class="card-body">
          <% if @approved_applications.any? %>
            <div class="table-responsive">
              <table class="table table-striped">
                <thead>
                  <tr>
                    <th>Student</th>
                    <th>Email</th>
                    <th>Course Applied For</th>
                    <th>Position</th>
                    <th>Hours</th>
                    <th>Assign To Section</th>
                  </tr>
                </thead>
                <tbody>
                  <% @approved_applications.each do |application| %>
                    <tr>
                      <td><%= application.user.name rescue 'N/A' %></td>
                      <td><%= application.user.email %></td>
                      <td><%= application.course.subject %> <%= application.course.course_number %></td>
                      <td><%= application.position_type.titleize %></td>
                      <td><%= application.hours_per_week %> hrs/week</td>
                      <td>
                        <%= form_with url: assign_grader_admin_grader_assignments_path, method: :patch, class: 'd-flex' do |f| %>
                          <%= f.hidden_field :application_id, value: application.id %>
                          <%= f.select :section_id, 
                            application.course.sections.map { |s| ["Section #{s.number} (#{s.instructor_name})", s.id] }, 
                            { include_blank: 'Select Section' }, 
                            { class: 'form-select form-select-sm me-2' } %>
                          <%= f.submit 'Assign', class: 'btn btn-sm btn-primary' %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="alert alert-info">
              No unassigned approved graders available.
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4">
    <%= link_to 'Back to Admin Dashboard', admin_users_path, class: 'btn btn-secondary' %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const courseSearch = document.getElementById('course-search');
    const statusFilter = document.getElementById('status-filter');
    const sectionRows = document.querySelectorAll('.section-row');
    
    function filterSections() {
      const searchTerm = courseSearch.value.toLowerCase();
      const statusValue = statusFilter.value;
      
      sectionRows.forEach(row => {
        const courseName = row.getAttribute('data-course').toLowerCase();
        const isNeedsGraders = row.classList.contains('needs-graders');
        const isFullyStaffed = row.classList.contains('fully-staffed');
        
        let showByStatus = true;
        if (statusValue === 'needs') {
          showByStatus = isNeedsGraders;
        } else if (statusValue === 'staffed') {
          showByStatus = isFullyStaffed;
        }
        
        const matchesSearch = courseName.includes(searchTerm);
        
        if (matchesSearch && showByStatus) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    }
    
    courseSearch.addEventListener('input', filterSections);
    statusFilter.addEventListener('change', filterSections);
  });
</script> 