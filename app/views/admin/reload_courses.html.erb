<div class="bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="sm:flex sm:items-center">
      <div class="sm:flex-auto">
        <h1 class="text-3xl font-semibold leading-6 text-gray-900">Reload Course Data</h1>
        <p class="mt-2 text-sm text-gray-700">Update the course catalog by fetching the latest data from the OSU API.</p>
      </div>
    </div>

    <div class="mt-8 bg-white p-6 rounded-lg shadow">
      <%= form_tag admin_reload_courses_path, method: :post, class: "space-y-6" do %>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <!-- Term Selection -->
          <div>
            <%= label_tag :term, "Term", class: "block text-sm font-medium text-gray-700" %>
            <%= select_tag :term,
                options_for_select([
                  ["Spring 2024", "1242"],
                  ["Summer 2024", "1244"],
                  ["Fall 2024", "1246"],
                  ["Spring 2025", "1252"]
                ]),
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
            <p class="mt-2 text-sm text-gray-500">Select the academic term to load courses for.</p>
          </div>

          <!-- Campus Selection -->
          <div>
            <%= label_tag :campus, "Campus", class: "block text-sm font-medium text-gray-700" %>
            <%= select_tag :campus,
                options_for_select([
                  ["Columbus", "col"],
                  ["Newark", "new"],
                  ["Marion", "mar"],
                  ["Lima", "lim"],
                  ["Mansfield", "man"],
                  ["Wooster", "woo"]
                ]),
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
            <p class="mt-2 text-sm text-gray-500">Select the campus location.</p>
          </div>

          <!-- Academic Career -->
          <div>
            <%= label_tag :academic_career, "Academic Career", class: "block text-sm font-medium text-gray-700" %>
            <%= select_tag :academic_career,
                options_for_select([
                  ["Undergraduate", "ugrad"],
                  ["Graduate", "grad"],
                  ["All", ""]
                ]),
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
            <p class="mt-2 text-sm text-gray-500">Filter courses by academic level.</p>
          </div>

          <!-- Subject -->
          <div>
            <%= label_tag :subject, "Subject", class: "block text-sm font-medium text-gray-700" %>
            <%= text_field_tag :subject, "CSE",
                readonly: true,
                class: "mt-1 block w-full rounded-md border-gray-300 bg-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
            <p class="mt-2 text-sm text-gray-500">Currently limited to CSE courses only.</p>
          </div>
        </div>

        <!-- Warning Message -->
        <div class="rounded-md bg-yellow-50 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-yellow-800">Important Note</h3>
              <div class="mt-2 text-sm text-yellow-700">
                <p>
                  This action will update the course database with fresh data from the OSU API. Existing course data will be replaced.
                  Make sure to review the parameters before proceeding.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Submit Button -->
        <div class="flex justify-end">
          <%= submit_tag "Reload Course Data",
              class: "rounded-md bg-blue-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600",
              data: { confirm: "Are you sure you want to reload the course data? This action cannot be undone." } %>
        </div>
      <% end %>
    </div>
  </div>
</div> 