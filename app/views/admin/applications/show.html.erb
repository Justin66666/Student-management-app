<div class="container">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <h1>Application Details</h1>
      
      <div class="d-flex justify-content-end mb-4">
        <%= link_to 'Edit', edit_admin_application_path(@application), class: 'btn btn-primary me-2' %>
        <%= button_to 'Delete', admin_course_application_path(@application.course, @application), 
            method: :delete, 
            class: 'btn btn-danger',
            data: { confirm: 'Are you sure you want to delete this application?' },
            form: { style: 'display: inline-block;' } %>
      </div>
      
      <% if @recommendation_letter.present? %>
        <div class="alert alert-info">
          <h5><i class="bi bi-info-circle"></i> Recommendation-based Application</h5>
          <p>This application was created automatically based on an instructor recommendation.</p>
          <%= link_to 'View Recommendation Letter', admin_recommendation_letter_path(@recommendation_letter), class: 'btn btn-sm btn-info' %>
        </div>
      <% end %>
      
      <div class="card mb-4">
        <div class="card-header">
          <h4>Application Status</h4>
        </div>
        <div class="card-body">
          <p><strong>Status:</strong> 
            <span class="badge <%= @application.status == 'pending' ? 'bg-warning' : (@application.status == 'approved' ? 'bg-success' : 'bg-danger') %>">
              <%= @application.status.titleize %>
            </span>
          </p>
          <p><strong>Submitted on:</strong> <%= @application.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
          
          <% if @application.status == 'pending' %>
            <div class="mt-3">
              <h5>Actions</h5>
              <div class="btn-group">
                <%= button_to approve_admin_application_path(@application),
                    method: :patch,
                    class: 'btn btn-success me-2',
                    style: 'display: inline-block;' do %>
                  Approve
                <% end %>
                
                <%= button_to reject_admin_application_path(@application),
                    method: :patch,
                    class: 'btn btn-danger',
                    style: 'display: inline-block;' do %>
                  Reject
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      
      <div class="card mb-4">
        <div class="card-header">
          <h4>Student Information</h4>
        </div>
        <div class="card-body">
          <p><strong>Email:</strong> <%= @application.user.email %></p>
          <p><strong>Role:</strong> <%= @application.user.role.titleize %></p>
        </div>
      </div>
      
      <div class="card mb-4">
        <div class="card-header">
          <h4>Course Information</h4>
        </div>
        <div class="card-body">
          <p><strong>Course:</strong> <%= @application.course.subject %> <%= @application.course.course_number %> - <%= @application.course.title %></p>
          <p><strong>Term:</strong> <%= @application.course.term %></p>
          <p><strong>Campus:</strong> <%= @application.course.campus %></p>
        </div>
      </div>
      
      <div class="card mb-4">
        <div class="card-header">
          <h4>Application Details</h4>
        </div>
        <div class="card-body">
          <p><strong>Position:</strong> <%= @application.position_type.titleize %></p>
          <p><strong>Programming Languages:</strong> <%= @application.programming_languages %></p>
          <p><strong>Available Hours:</strong> <%= @application.available_hours %> hrs/week</p>
          
          <div class="mt-3">
            <h5>Experience</h5>
            <div class="p-3 bg-light border rounded">
              <%= simple_format(@application.experience) %>
            </div>
          </div>
        </div>
      </div>
      
      <div class="mt-4">
        <%= link_to admin_applications_path, class: 'btn btn-secondary' do %>
          <i class="bi bi-arrow-left"></i> Back to Applications
        <% end %>
        
        <%= link_to admin_users_path, class: 'btn btn-primary ms-2' do %>
          <i class="bi bi-house-door"></i> Back to Dashboard
        <% end %>
      </div>
    </div>
  </div>
</div> 