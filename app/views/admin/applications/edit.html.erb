<div class="container">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <h1>Edit Application</h1>
      
      <%= form_with(model: [@course, @application], url: admin_course_application_path(@course, @application), method: :patch, local: true, class: 'mt-4') do |f| %>
        <% if @application.errors.any? %>
          <div class="alert alert-danger">
            <h2><%= pluralize(@application.errors.count, "error") %> prohibited this application from being saved:</h2>
            <ul>
              <% @application.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        
        <div class="card mb-4">
          <div class="card-header">
            <h4>Student Information</h4>
          </div>
          <div class="card-body">
            <p><strong>Student:</strong> <%= @application.user.email %></p>
          </div>
        </div>
        
        <div class="card mb-4">
          <div class="card-header">
            <h4>Application Details</h4>
          </div>
          <div class="card-body">
            <div class="mb-3">
              <%= f.label :position_type, 'Position', class: 'form-label' %>
              <%= f.select :position_type, options_for_select([['Grader', 'grader'], ['Teaching Assistant', 'teaching_assistant'], ['Lab Assistant', 'lab_assistant']], @application.position_type), {}, { class: 'form-select' } %>
            </div>
            
            <div class="mb-3">
              <%= f.label :experience, 'Experience', class: 'form-label' %>
              <%= f.text_area :experience, class: 'form-control', rows: 4 %>
            </div>
            
            <div class="mb-3">
              <%= f.label :programming_languages, 'Programming Languages', class: 'form-label' %>
              <%= f.text_field :programming_languages, class: 'form-control' %>
            </div>
            
            <div class="mb-3">
              <%= f.label :available_hours, 'Available Hours per Week', class: 'form-label' %>
              <%= f.number_field :available_hours, class: 'form-control', min: 1, max: 40 %>
            </div>
            
            <div class="mb-3">
              <%= f.label :status, 'Status', class: 'form-label' %>
              <%= f.select :status, options_for_select([['Pending', 'pending'], ['Approved', 'approved'], ['Rejected', 'rejected']], @application.status), {}, { class: 'form-select' } %>
            </div>
          </div>
        </div>
        
        <div class="d-flex justify-content-between mt-4">
          <%= link_to 'Back', admin_course_application_path(@course, @application), class: 'btn btn-secondary' %>
          <%= f.submit 'Update Application', class: 'btn btn-primary' %>
        </div>
      <% end %>
    </div>
  </div>
</div> 