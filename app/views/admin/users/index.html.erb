<h1>User Management</h1>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div class="alert alert-info mb-0 flex-grow-1">
    <i class="bi bi-info-circle"></i> 
    <strong>Dashboard Home</strong> - From here you can navigate to all admin functions
  </div>
  <%= link_to root_path, class: "btn btn-lg btn-primary ms-3" do %>
    <i class="bi bi-house-door"></i> Return to Main Homepage
  <% end %>
</div>

<div class="row mb-4">
  <div class="col-md-4">
    <%= link_to admin_applications_path, class: "card text-center p-3 h-100 text-decoration-none" do %>
      <div class="card-body">
        <i class="bi bi-file-earmark-text fs-1"></i>
        <h5 class="mt-2">Applications</h5>
        <p class="text-muted">Manage student applications</p>
      </div>
    <% end %>
  </div>
  <div class="col-md-4">
    <%= link_to admin_recommendation_letters_path, class: "card text-center p-3 h-100 text-decoration-none" do %>
      <div class="card-body">
        <i class="bi bi-award fs-1"></i>
        <h5 class="mt-2">Recommendations</h5>
        <p class="text-muted">Manage teacher recommendations</p>
        <% pending_recommendations = RecommendationLetter.where(status: 'pending').count %>
        <% if pending_recommendations > 0 %>
          <span class="badge bg-warning text-dark"><%= pending_recommendations %> pending</span>
        <% end %>
      </div>
    <% end %>
  </div>
  <div class="col-md-4">
    <%= link_to admin_courses_reload_path, class: "card text-center p-3 h-100 text-decoration-none" do %>
      <div class="card-body">
        <i class="bi bi-book fs-1"></i>
        <h5 class="mt-2">Courses</h5>
        <p class="text-muted">Manage course catalog</p>
      </div>
    <% end %>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-4">
    <%= link_to admin_grader_assignments_path, class: "card text-center p-3 h-100 text-decoration-none" do %>
      <div class="card-body">
        <i class="bi bi-person-workspace fs-1"></i>
        <h5 class="mt-2">Grader Assignments</h5>
        <p class="text-muted">Assign graders to sections</p>
      </div>
    <% end %>
  </div>
  <div class="col-md-4">
    <%= link_to admin_users_path, class: "card text-center p-3 h-100 text-decoration-none bg-light" do %>
      <div class="card-body">
        <i class="bi bi-people fs-1"></i>
        <h5 class="mt-2">Users</h5>
        <p class="text-muted">Manage user accounts</p>
      </div>
    <% end %>
  </div>
  <div class="col-md-4">
    <!-- 占位，可以在未来添加其他功能 -->
  </div>
</div>

<div class="table-responsive">
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Email</th>
        <th>Role</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.email %></td>
          <td><%= user.role.titleize %></td>
          <td>
            <% if user.approved? %>
              <span class="badge bg-success">Approved</span>
            <% else %>
              <span class="badge bg-warning">Pending</span>
            <% end %>
          </td>
          <td>
            <%= link_to 'Edit', edit_admin_user_path(user), class: 'btn btn-sm btn-primary' %>
            <% unless user.approved? %>
              <%= button_to 'Approve', approve_admin_user_path(user), method: :patch, class: 'btn btn-sm btn-success' %>
            <% end %>
            <%= button_to 'Delete', admin_user_path(user), method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-sm btn-danger' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div> 