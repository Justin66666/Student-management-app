<div class="container">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <h1>Submit Recommendation Letter</h1>
      <p class="text-muted">
        For course: <strong><%= @course.subject %> <%= @course.course_number %> - <%= @course.title %></strong>
      </p>
      
      <%= form_with(model: [:instructor, @course, @recommendation_letter], local: true, class: 'mt-4') do |f| %>
        <% if @recommendation_letter.errors.any? %>
          <div class="alert alert-danger">
            <h2><%= pluralize(@recommendation_letter.errors.count, "error") %> prohibited this recommendation from being saved:</h2>
            <ul>
              <% @recommendation_letter.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        
        <div class="card mb-4">
          <div class="card-header">
            <h4>Your Information</h4>
          </div>
          <div class="card-body">
            <div class="mb-3">
              <%= f.label :instructor_name, 'Your Name', class: 'form-label' %>
              <%= f.text_field :instructor_name, value: current_user.email.split('@').first.split('.').first.titleize, class: 'form-control' %>
            </div>
            
            <p class="text-muted">
              Your email (<%= current_user.email %>) will be automatically associated with this recommendation.
            </p>
          </div>
        </div>
        
        <div class="card mb-4">
          <div class="card-header">
            <h4>Student Information</h4>
          </div>
          <div class="card-body">
            <div class="mb-3">
              <%= f.label :student_name, 'Student Name', class: 'form-label' %>
              <%= f.text_field :student_name, class: 'form-control', placeholder: 'Enter student\'s full name' %>
            </div>
            
            <div class="mb-3">
              <%= f.label :student_email, 'Student Email', class: 'form-label' %>
              <%= f.email_field :student_email, class: 'form-control', placeholder: 'Enter student\'s OSU email (name.#@osu.edu)' %>
              <div class="form-text">Must be a valid OSU email (name.#@osu.edu)</div>
            </div>
          </div>
        </div>
        
        <div class="card mb-4">
          <div class="card-header">
            <h4>Recommendation Content</h4>
          </div>
          <div class="card-body">
            <div class="mb-3">
              <%= f.label :content, 'Content', class: 'form-label' %>
              <%= f.text_area :content, class: 'form-control', rows: 8,
                  placeholder: 'Please explain why you recommend this student to be a grader for this course. Include their qualifications, experience, and any other relevant information.' %>
            </div>
          </div>
        </div>
        
        <div class="d-flex justify-content-between mt-4">
          <%= link_to 'Back', instructor_course_path(@course), class: 'btn btn-secondary' %>
          <%= f.submit 'Submit Recommendation', class: 'btn btn-primary' %>
        </div>
      <% end %>
    </div>
  </div>
</div> 